# ============================================
# FormPilot AI Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ─── APP ──────────────────────────────────────
NODE_ENV=development
PORT=5000
APP_NAME=FormPilot AI

# ─── DATABASE ────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/formpilot?retryWrites=true&w=majority

# ─── JWT ─────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_this
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_min_32_chars
JWT_REFRESH_EXPIRE=30d

# ─── CORS ────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app,chrome-extension://YOUR_EXTENSION_ID

# ─── GEMINI AI ───────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_from_google_ai_studio

# ─── RATE LIMITING ───────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── BCRYPT ──────────────────────────────────
BCRYPT_ROUNDS=12

# ─── FILE UPLOAD ─────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
